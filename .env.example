# ── Model & Search ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=data/faiss.index
INTERNSHIP_DATA_PATH=data/internships.csv
TOP_K_RESULTS=10
SEMANTIC_WEIGHT=0.70
KEYWORD_WEIGHT=0.30

# ── Caching (optional) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Text Limits ────────────────────────────────────────────────────────────
MAX_TEXT_LENGTH=10000
